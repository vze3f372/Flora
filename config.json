{
  "theme": "cyan",
  "refreshSeconds": 3,
  "panels": {
    "raids": {
      "title": "TOP RAIDERS",
      "subtitle": "THANK YOU FOR THE SUPPORT",
      "dataFile": "data/raids.json",
      "maxRows": 10,
      "sortBy": "viewers",
      "sortThenBy": "raids",
      "columns": [
        {
          "label": "Viewers",
          "field": "viewers",
          "className": "primary-number",
          "align": "center",
          "width": "150px"
        },
        {
          "label": "Raids",
          "field": "raids",
          "className": "secondary-number",
          "align": "center",
          "width": "110px"
        }
      ],
      "scroll": {
        "enabled": true,
        "speedPixelsPerSecond": 24,
        "startDelaySeconds": 1,
        "gapPixels": 20
      },
      "type": "table",
      "emptyMessage": "No raids recorded yet",
      "rankLabel": "Rank",
      "nameLabel": "Raider"
    },
    "bits": {
      "title": "TOP BITS",
      "subtitle": "THANK YOU FOR THE SUPPORT",
      "dataFile": "data/bits.json",
      "maxRows": 10,
      "sortBy": "bits",
      "sortThenBy": "cheers",
      "columns": [
        {
          "label": "Bits",
          "field": "bits",
          "className": "primary-number",
          "align": "center",
          "width": "150px"
        },
        {
          "label": "Cheers",
          "field": "cheers",
          "className": "secondary-number",
          "align": "center",
          "width": "110px"
        }
      ],
      "scroll": {
        "enabled": true,
        "speedPixelsPerSecond": 24,
        "startDelaySeconds": 1,
        "gapPixels": 20
      },
      "type": "table",
      "emptyMessage": "No bits recorded yet",
      "rankLabel": "Rank",
      "nameLabel": "User"
    },
    "follower-goal": {
      "type": "goal",
      "title": "FOLLOWER GOAL",
      "subtitle": "THANK YOU FOR THE SUPPORT",
      "dataFile": "data/goals.json",
      "goalKey": "followers",
      "currentLabel": "Followers",
      "targetLabel": "Goal",
      "percentLabel": "Complete",
      "numberFormat": "plain",
      "completeMessage": "Goal reached!",
      "showPercent": true,
      "progressFill": "#5eead4",
      "progressEmpty": "#16323a"
    },
    "recent-events": {
      "type": "events",
      "title": "RECENT ACTIVITY",
      "subtitle": "LATEST STREAM EVENTS",
      "dataFile": "data/events.json",
      "maxEvents": 8,
      "emptyMessage": "No recent events yet",
      "typeLabel": "Event",
      "nameLabel": "User",
      "detailLabel": "Details",
      "timeLabel": "Time",
      "eventTypes": {
        "raid": {
          "label": "RAID",
          "color": "#5eead4"
        },
        "bits": {
          "label": "BITS",
          "color": "#67e8f9"
        },
        "goal": {
          "label": "GOAL",
          "color": "#a78bfa"
        },
        "follow": {
          "label": "FOLLOW",
          "color": "#86efac"
        },
        "sub": {
          "label": "SUB",
          "color": "#f0abfc"
        }
      }
    },
    "sub-goal": {
      "type": "goal",
      "title": "SUB GOAL",
      "subtitle": "THANK YOU FOR THE SUPPORT",
      "dataFile": "data/goals.json",
      "goalKey": "subscribers",
      "currentLabel": "Subs",
      "targetLabel": "Goal",
      "percentLabel": "Complete",
      "numberFormat": "plain",
      "completeMessage": "Sub goal reached!",
      "showPercent": true,
      "progressFill": "#5eead4",
      "progressEmpty": "#16323a"
    }
  },
  "rotation": {
    "enabled": false,
    "panels": [
      {
        "panel": "raids",
        "durationSeconds": 10
      },
      {
        "panel": "bits",
        "durationSeconds": 10
      },
      {
        "panel": "follower-goal",
        "durationSeconds": 12
      },
      {
        "panel": "recent-events",
        "durationSeconds": 10
      }
    ],
    "transitionMilliseconds": 500,
    "startPanel": "bits"
  }
}
